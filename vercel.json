{
  "version": 2,
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/image", "destination": "/api/image" },
    { "source": "/app", "destination": "/public/app/index.html" },
    { "source": "/app/(.*)", "destination": "/public/app/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
